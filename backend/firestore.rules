rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isStaff() {
      return isSignedIn() &&
        (request.auth.token.role == 'staff' || request.auth.token.role == 'admin');
    }

    match /campusState/{campusId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isStaff();
      allow create, update: if isOwner(uid) || isStaff();
      allow delete: if false;
    }

    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /updates/{updateId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /reports/{uid} {
        allow read: if isOwner(uid) || isStaff();
        allow create, update, delete: if false;
      }

      match /trustVotes/{uid} {
        allow read: if isOwner(uid) || isStaff();
        allow create, update, delete: if false;
      }

      match /updateRequests/{uid} {
        allow read: if isOwner(uid) || isStaff();
        allow create, update, delete: if false;
      }
    }
  }
}
