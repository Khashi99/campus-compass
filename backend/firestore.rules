rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasRoleDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid));
    }

    function isStaff() {
      return hasRoleDoc() && (
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'staff' ||
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidCampusId(value) {
      return value in ['sgw', 'loyola'];
    }

    function isValidIncidentType(value) {
      return value in ['protest', 'construction', 'gathering', 'blockage', 'emergency', 'maintenance'];
    }

    function isValidIncidentStatus(value) {
      return value in ['submitted', 'reported', 'investigating', 'resolved', 'dismissed'];
    }

    function isValidVerificationLevel(value) {
      return value in ['unverified', 'userReported', 'verified'];
    }

    function isValidVote(value) {
      return value in ['confirm', 'dispute'];
    }

    function isValidAlertMode(value) {
      return value in ['haptic_visual', 'visual', 'haptic', 'silent'];
    }

    function isValidCoordinates(value) {
      return value is map &&
        value.latitude is number &&
        value.longitude is number &&
        value.latitude >= -90 &&
        value.latitude <= 90 &&
        value.longitude >= -180 &&
        value.longitude <= 180;
    }

    match /roles/{uid} {
      allow read: if isOwner(uid) || isStaff();
      allow write: if false;
    }

    match /campusState/{campusId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isStaff();
      allow create, update: if isOwner(uid) &&
        request.resource.data.keys().hasOnly([
          'displayName',
          'alertPreference',
          'createdAt',
          'updatedAt'
        ]) &&
        (!('displayName' in request.resource.data) || request.resource.data.displayName is string) &&
        request.resource.data.alertPreference is map &&
        request.resource.data.alertPreference.mode is string &&
        isValidAlertMode(request.resource.data.alertPreference.mode);
      allow delete: if false;
    }

    match /incidentReports/{reportId} {
      allow read: if isStaff() || isOwner(resource.data.createdBy);
      // Allow creation from signed-in users. Permit optional media fields
      // (`imageUrl`, `videoUrl`, `evidence`) while validating basic types.
      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly([
          'campusId',
          'title',
          'description',
          'location',
          'coordinates',
          'buildingCode',
          'type',
          'status',
          'verificationLevel',
          'createdBy',
          'linkedIncidentId',
          'imageUrl',
          'videoUrl',
          'evidence',
          'reportedTime',
          'updatedAt'
        ]) &&
        isValidCampusId(request.resource.data.campusId) &&
        isValidIncidentType(request.resource.data.type) &&
        isValidIncidentStatus(request.resource.data.status) &&
        isValidVerificationLevel(request.resource.data.verificationLevel) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status in ['reported', 'submitted'] &&
        request.resource.data.verificationLevel == 'userReported' &&
        request.resource.data.title is string &&
        request.resource.data.description is string &&
        request.resource.data.location is string &&
        isValidCoordinates(request.resource.data.coordinates) &&
        // Optional media fields: allow absent or null, otherwise validate types.
        (!('imageUrl' in request.resource.data) || request.resource.data.imageUrl == null || request.resource.data.imageUrl is string) &&
        (!('videoUrl' in request.resource.data) || request.resource.data.videoUrl == null || request.resource.data.videoUrl is string) &&
        (!('evidence' in request.resource.data) || request.resource.data.evidence is list);
      // Staff can update/delete any report. Report owners may update only
      // the media-related fields after creation (so the client can upload
      // files and then `update` the document with URLs/evidence).
      allow update: if isStaff() || (
        isOwner(resource.data.createdBy) &&
        // Owner may only modify these keys on update.
        request.resource.data.keys().hasOnly([
          'campusId',
          'title',
          'description',
          'location',
          'coordinates',
          'buildingCode',
          'type',
          'status',
          'verificationLevel',
          'createdBy',
          'linkedIncidentId',
          'imageUrl',
          'videoUrl',
          'evidence',
          'reportedTime',
          'updatedAt'
        ]) &&
        // Ensure createdBy cannot be changed and remains the original owner.
        request.resource.data.createdBy == resource.data.createdBy
      );
      allow delete: if isStaff();
    }

    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff();

      match /updates/{updateId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isStaff();
      }

      match /trustVotes/{uid} {
        allow read: if isOwner(uid) || isStaff();
        allow create, update: if isOwner(uid) &&
          request.resource.data.keys().hasOnly([
            'uid',
            'vote',
            'submittedAt',
            'updatedAt'
          ]) &&
          request.resource.data.uid == request.auth.uid &&
          isValidVote(request.resource.data.vote);
        allow delete: if isOwner(uid) || isStaff();
      }

      match /updateRequests/{uid} {
        allow read: if isOwner(uid) || isStaff();
        allow create, update: if isOwner(uid) &&
          request.resource.data.keys().hasOnly([
            'uid',
            'message',
            'requestedAt',
            'updatedAt'
          ]) &&
          request.resource.data.uid == request.auth.uid &&
          (!('message' in request.resource.data) || request.resource.data.message is string);
        allow delete: if isOwner(uid) || isStaff();
      }
    }
  }
}
